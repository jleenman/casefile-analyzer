{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://casefile-analyzer.org/schemas/signal.schema.json",
  "title": "Signal",
  "type": "object",
  "required": ["signalId", "caseId", "category", "severity", "confidence", "summary", "evidenceRefs", "reviewStatus"],
  "additionalProperties": false,
  "properties": {
    "signalId": { "type": "string" },
    "caseId": { "type": "string" },
    "category": {
      "type": "string",
      "enum": [
        "dreiging",
        "intimidatie",
        "stalking",
        "dwingende_controle",
        "isolatie",
        "financiele_controle",
        "kinderen_omgangsdruk",
        "juridische_druk",
        "zorg_school",
        "escalatie",
        "de_escalatie_rustperiode",
        "inconsistenties"
      ]
    },
    "severity": { "type": "integer", "minimum": 1, "maximum": 5 },
    "confidence": { "type": "string", "enum": ["laag", "middel", "hoog"] },
    "summary": { "type": "string" },
    "rationale": { "type": "string" },
    "evidenceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["evidenceId", "sourceId", "sourceRef"],
        "additionalProperties": false,
        "properties": {
          "evidenceId": { "type": "string" },
          "sourceId": { "type": "string" },
          "quotedText": { "type": "string" },
          "sourceRef": {
            "type": "object",
            "required": ["filename"],
            "additionalProperties": false,
            "properties": {
              "filename": { "type": "string" },
              "lineStart": { "type": "integer", "minimum": 1 },
              "lineEnd": { "type": "integer", "minimum": 1 },
              "page": { "type": "integer", "minimum": 1 },
              "timestampStart": { "type": "string" },
              "timestampEnd": { "type": "string" }
            }
          }
        }
      }
    },
    "uncertainty": { "type": "string" },
    "reviewStatus": { "type": "string", "enum": ["unreviewed", "reviewed", "rejected"] }
  }
}
