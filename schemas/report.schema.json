{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://casefile-analyzer.org/schemas/report.schema.json",
  "title": "Report",
  "type": "object",
  "required": ["reportId", "caseId", "createdAt", "format", "sections", "sourceIndex"],
  "additionalProperties": false,
  "properties": {
    "reportId": { "type": "string" },
    "caseId": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "format": { "type": "string", "enum": ["markdown", "pdf"] },
    "storageKey": { "type": "string" },
    "disclaimer": { "type": "string" },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "content"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "content": { "type": "string" },
          "signalIds": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "sourceIndex": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sourceId", "filename"],
        "additionalProperties": false,
        "properties": {
          "sourceId": { "type": "string" },
          "filename": { "type": "string" },
          "mediaType": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
